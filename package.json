{
  "name": "handsealed-monorepo",
  "private": true,
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && node scripts/executable-bins.mjs",
    "test": "npm run build && node --test \"packages/*/dist/**/*.test.js\" \"scripts/**/*.test.mjs\"",
    "lint": "oxlint packages scripts",
    "fmt": "oxfmt packages scripts",
    "fmt:check": "oxfmt --check packages scripts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "typescript": "^7.0.2"
  }
}
