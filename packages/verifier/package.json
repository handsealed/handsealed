{
  "name": "@handsealed/verifier",
  "version": "0.5.0",
  "description": "The Handsealed CLI: replay every verdict offline against a clone. Don't trust us — verify.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/handsealed/handsealed.git",
    "directory": "packages/verifier"
  },
  "bin": {
    "handsealed": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./reporter": {
      "types": "./dist/reporter.d.ts",
      "default": "./dist/reporter.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@handsealed/engine": "^0.5.0",
    "@handsealed/facts-git": "^0.5.0"
  },
  "engines": {
    "node": ">=22"
  }
}
